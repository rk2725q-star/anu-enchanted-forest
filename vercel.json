{
      "version": 2,
      "builds": [
              {
                        "src": "package.json",
                        "use": "@vercel/static-build",
                        "config": {
                                    "distDir": "dist"
                        }
              },
              {
                        "src": "api/index.ts",
                        "use": "@vercel/node"
              }
      ],
      "functions": {
              "api/index.ts": {
                        "includeFiles": "src/services/**"
              }
      },
      "routes": [
              {
                        "src": "/api/(.*)",
                        "dest": "api/index.ts"
              },
              {
                        "src": "/uploads/(.*)",
                        "dest": "/uploads/$1"
              }
      ]
}
